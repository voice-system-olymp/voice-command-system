<mxfile>
  <diagram name="DFD Level 0" id="dfd0">
    <mxGraphModel dx="900" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="800" pageHeight="500">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- External entity: Operator -->
        <mxCell id="op" value="Оператор" style="shape=rectangle;rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=14;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="80" y="200" width="140" height="60" as="geometry"/>
        </mxCell>

        <!-- Process -->
        <mxCell id="proc" value="Система распознавания&#xa;голосовых команд" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="320" y="170" width="220" height="120" as="geometry"/>
        </mxCell>

        <!-- Data store -->
        <mxCell id="db" value="БД PostgreSQL" style="shape=partialRectangle;top=0;left=0;bottom=1;right=0;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=13;strokeWidth=2;html=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="210" width="140" height="40" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" value="Аудиозапись (голос)" style="endArrow=block;endFill=1;strokeWidth=2;fontSize=11;html=1;" edge="1" source="op" target="proc" parent="1">
          <mxGeometry x="0.1" y="15" relative="1" as="geometry">
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="e2" value="Результат распознавания" style="endArrow=block;endFill=1;strokeWidth=2;fontSize=11;html=1;" edge="1" source="proc" target="op" parent="1">
          <mxGeometry x="0.1" y="-15" relative="1" as="geometry">
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="e3" value="Данные записей" style="endArrow=block;endFill=1;strokeWidth=2;fontSize=11;html=1;" edge="1" source="proc" target="db" parent="1">
          <mxGeometry x="0.1" y="15" relative="1" as="geometry">
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="e4" value="Данные пользователей" style="endArrow=block;endFill=1;strokeWidth=2;fontSize=11;html=1;" edge="1" source="db" target="proc" parent="1">
          <mxGeometry x="0.1" y="-15" relative="1" as="geometry">
            <mxPoint as="offset"/>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
