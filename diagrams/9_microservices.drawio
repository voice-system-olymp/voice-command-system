<mxfile>
  <diagram name="Целевая микросервисная архитектура" id="ms1">
    <mxGraphModel dx="1100" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="550">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Frontend -->
        <mxCell id="client" value="Frontend&#xa;(React SPA)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=13;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="210" width="140" height="70" as="geometry"/>
        </mxCell>

        <!-- API Service -->
        <mxCell id="api" value="API Service&#xa;CRUD + Auth" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=13;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="280" y="210" width="160" height="70" as="geometry"/>
        </mxCell>

        <!-- Queue -->
        <mxCell id="queue" value="Очередь задач&#xa;Redis / RabbitMQ" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="530" y="200" width="160" height="90" as="geometry"/>
        </mxCell>

        <!-- ASR Worker -->
        <mxCell id="worker" value="ASR Worker&#xa;VOSK + Parser" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=13;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="790" y="210" width="160" height="70" as="geometry"/>
        </mxCell>

        <!-- PostgreSQL -->
        <mxCell id="db" value="PostgreSQL" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f5f5f5;strokeColor=#666666;fontStyle=1;fontSize=13;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="430" y="420" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- S3 -->
        <mxCell id="s3" value="S3 Storage" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=15;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=1;fontSize=13;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="680" y="420" width="140" height="80" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" value="REST API" style="endArrow=block;endFill=1;strokeWidth=2;fontSize=11;html=1;" edge="1" source="client" target="api" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2" value="задача" style="endArrow=block;endFill=1;strokeWidth=2;fontSize=11;html=1;" edge="1" source="api" target="queue" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3" value="получение" style="endArrow=block;endFill=1;strokeWidth=2;fontSize=11;html=1;" edge="1" source="queue" target="worker" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e4" value="CRUD" style="endArrow=block;endFill=1;strokeWidth=2;fontSize=11;html=1;" edge="1" source="api" target="db" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e5" value="результат" style="endArrow=block;endFill=1;strokeWidth=2;fontSize=11;html=1;" edge="1" source="worker" target="db" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e6" value="WAV" style="endArrow=block;endFill=1;strokeWidth=2;fontSize=11;html=1;" edge="1" source="worker" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e7" value="presigned URL" style="endArrow=block;endFill=1;strokeWidth=2;fontSize=11;html=1;dashed=1;" edge="1" source="api" target="s3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
