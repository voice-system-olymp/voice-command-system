<mxfile>
  <diagram name="Схема обработки голосовой команды" id="flow1">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="700">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Participants -->
        <mxCell id="mic_h" value="Микрофон" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#dae8fc;strokeColor=#6c8ebf;size=40;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="30" width="100" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="br_h" value="Браузер" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#fff2cc;strokeColor=#d6b656;size=40;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="30" width="100" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="be_h" value="Backend" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#d5e8d4;strokeColor=#82b366;size=40;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="500" y="30" width="100" height="560" as="geometry"/>
        </mxCell>
        <mxCell id="db_h" value="БД" style="shape=umlLifeline;perimeter=lifelinePerimeter;whiteSpace=wrap;html=1;container=0;collapsible=0;recursiveResize=0;outlineConnect=0;fillColor=#e1d5e7;strokeColor=#9673a6;size=40;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="720" y="30" width="100" height="560" as="geometry"/>
        </mxCell>

        <!-- Messages -->
        <mxCell id="m1" value="Аудиопоток" style="html=1;verticalAlign=bottom;endArrow=block;entryX=0;entryY=0;exitX=1;exitY=0;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="130" y="110" as="sourcePoint"/>
            <mxPoint x="330" y="110" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m2" value="WebM/Opus blob" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="330" y="160" as="sourcePoint"/>
            <mxPoint x="550" y="160" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m3" value="ffmpeg: WebM в WAV 16kHz" style="html=1;verticalAlign=bottom;endArrow=block;curved=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="210" as="sourcePoint"/>
            <mxPoint x="560" y="240" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="620" y="225"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="m4" value="VOSK: WAV в текст" style="html=1;verticalAlign=bottom;endArrow=block;curved=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="270" as="sourcePoint"/>
            <mxPoint x="560" y="300" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="620" y="285"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="m5" value="CommandParser: текст в команду" style="html=1;verticalAlign=bottom;endArrow=block;curved=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="560" y="330" as="sourcePoint"/>
            <mxPoint x="560" y="360" as="targetPoint"/>
            <Array as="points">
              <mxPoint x="620" y="345"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="m6" value="INSERT запись" style="html=1;verticalAlign=bottom;endArrow=block;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="400" as="sourcePoint"/>
            <mxPoint x="770" y="400" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        <mxCell id="m7" value="JSON результат" style="html=1;verticalAlign=bottom;endArrow=open;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="550" y="460" as="sourcePoint"/>
            <mxPoint x="330" y="460" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
